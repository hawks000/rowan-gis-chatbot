# =============================================================================
# Rowan County Web App - Application Configuration
# =============================================================================
# Copy this file to .env and fill in the values for local development.
# In production, these are injected via Portainer/Docker environment variables
# from GitHub Environment secrets and variables during CI/CD deployment.
# =============================================================================

# =============================================================================
# INFRASTRUCTURE (same pattern for every Rowan County web app)
# =============================================================================

# Environment (controls debug mode and behavior)
# Values: "production" or "development"
ENVIRONMENT=development

# Server port
PORT=5002

# Flask debug mode
FLASK_DEBUG=false

# -----------------------------------------------------------------------------
# SECRETS (these go in GitHub Environment Secrets -- write-only, hidden)
# In local .env you can set them directly. Never commit real values.
# -----------------------------------------------------------------------------

# Flask session secret key (generate a unique value for production)
FLASK_SECRET_KEY=dev-fallback-key-change-in-production

# Azure AD client secret (from app registration > Certificates & secrets)
AZURE_CLIENT_SECRET=your_client_secret_here

# Cloudflare tunnel token (from Zero Trust > Tunnels)
# Leave blank to disable the tunnel sidecar container for local dev.
CLOUDFLARE_TUNNEL_TOKEN=

# -----------------------------------------------------------------------------
# CONFIGURATION (these go in GitHub Environment Variables -- readable, auditable)
# Non-sensitive values that are safe to be visible in the GitHub UI.
# -----------------------------------------------------------------------------

# Microsoft Entra ID (Azure AD) Authentication
AUTH_ENABLED=false

# Auth access model:
#   allowlist - only specific emails listed in ALLOWED_USERS can log in (recommended)
#   all_org   - any user in the org matching the tenant + email domain can log in
AUTH_MODE=allowlist

# Comma-separated emails for allowlist mode (ignored when AUTH_MODE=all_org)
ALLOWED_USERS=

# Azure AD Application Registration
AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_TENANT_ID=977b42ab-7737-4552-86e7-b09ed296213d

# Redirect URIs (must match Azure AD app registration)
# Local dev: http://localhost:5001/getAToken
# Production: https://yourapp.rowancountync.io/getAToken
REDIRECT_URI=http://localhost:5001/getAToken
POST_LOGOUT_REDIRECT_URI=http://localhost:5001

# Authorization constraints (Rowan County defaults)
ALLOWED_TENANT_ID=977b42ab-7737-4552-86e7-b09ed296213d
ALLOWED_EMAIL_DOMAIN=@rowancountync.gov

# =============================================================================
# APP-SPECIFIC CONFIGURATION
# =============================================================================

# Public chat requires no login
AUTH_ENABLED=false

# Staff admin log at /admin/queries (set false for local dev without Azure AD)
ADMIN_AUTH_ENABLED=false

# ArcGIS public REST services
ARCGIS_BASE_URL=https://gis.rowancountync.gov/arcgis/rest/services
ARCGIS_BASEMAP_URL=https://gis.rowancountync.gov/arcgis/rest/services/Public/MapViewer/MapServer
ARCGIS_PICTOMETRY_URL=https://gis.rowancountync.gov/arcgis/rest/services/Pictometry/Pictometry2025/MapServer

# Optional: ArcGIS Online Web Map (uses AGOL popups/layers instead of basemap URL above)
# Find the item ID in your map URL, e.g. .../home/webmap/viewer.html?webmap=YOUR_ITEM_ID
# Map must be shared publicly (or portal must allow anonymous access).
ARCGIS_WEBMAP_ITEM_ID=
ARCGIS_PORTAL_URL=https://www.arcgis.com

PARCEL_LAYER_URL=Public/RowanTaxParcels/MapServer/0
APPROVED_SUBDIVISION_LAYER_URL=Public/IntranetMap/MapServer/27
FLOOD_PARCEL_LAYER_URL=Public/Open_Data_Downloads/MapServer/53
CITY_LIMITS_LAYER_URL=Public/Open_Data_Downloads/MapServer/41
FIRE_DISTRICT_LAYER_URL=Public/Public_Safety_Stations_and_Boundaries/MapServer/11
AIRPORT_OVERLAY_LAYER_URL=Public/AirportOverlay/MapServer/0
ZIP_CODE_LAYER_URL=Public/RowanZipCodes/MapServer/0
CHAT_DB_PATH=data/chatbot.db

ROWAN_ADDRESS_LAYER_URL=Public/search/MapServer/0

# NC OneMap geocoder (AddressNC) — fallback after Rowan addressing search
NCONEMAP_GEOCODER_URL=https://services.nconemap.gov/secure/rest/services/AddressNC/AddressNC_geocoder/GeocodeServer

# Phase 2 — Azure OpenAI (leave blank until API key is ready)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_KEY=
